{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pegasus project event",
  "type": "object",
  "required": ["time", "kind", "message"],
  "properties": {
    "time": { "type": "string" },
    "kind": {
      "type": "string",
      "enum": [
        "project_started",
        "spec_written",
        "task_created",
        "task_delegated",
        "agent_result",
        "status_updated",
        "question_added",
        "project_done",
        "project_stopped"
      ]
    },
    "message": { "type": "string" },
    "evidence": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
