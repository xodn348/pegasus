{
  "$schema": "https://pegasus.dev/schemas/workers.v2.json",
  "version": 2,
  "runtime": "claude-code-agent-tool",
  "workers": [
    {
      "name": "CEO",
      "model": "claude-opus-4-7",
      "system_prompt_path": "workers/ceo.md",
      "tools": ["Read", "Write", "WebFetch"]
    },
    {
      "name": "CTO",
      "model": "claude-haiku-4-5-20251001",
      "system_prompt_path": "workers/cto.md",
      "tools": ["Read", "Write", "Edit", "Bash", "Grep", "Glob", "WebFetch"]
    },
    {
      "name": "CFO",
      "model": "claude-haiku-4-5-20251001",
      "system_prompt_path": "workers/cfo.md",
      "tools": ["Read", "Write", "WebFetch"]
    },
    {
      "name": "CMO",
      "model": "claude-haiku-4-5-20251001",
      "system_prompt_path": "workers/cmo.md",
      "tools": ["Read", "Write", "WebFetch", "WebSearch"]
    },
    {
      "name": "COO",
      "model": "claude-haiku-4-5-20251001",
      "system_prompt_path": "workers/coo.md",
      "tools": ["Read", "Write", "WebSearch", "WebFetch"]
    },
    {
      "name": "General Counsel",
      "model": "claude-opus-4-7",
      "system_prompt_path": "workers/general-counsel.md",
      "tools": ["Read", "Write", "WebSearch", "WebFetch"]
    }
  ],
  "notes": {
    "runtime": "Workers are invoked via Claude Code's Agent tool — subagent_type='general-purpose', prompt = body of system_prompt_path file + task. No Anthropic Managed Agents API.",
    "model_tiering": "Opus for CEO + GC (judgment-heavy). Haiku for execution roles (CTO/CFO/CMO/COO).",
    "mcp": "Configured in the user's Claude Code MCP settings separately, not declared here.",
    "coordinator": "No separate coordinator agent. The Driver itself routes tasks per leader-driver.md §3 table."
  }
}
